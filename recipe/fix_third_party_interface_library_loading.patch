+def _load_built_library(build_dir):
+    ver = f"{torchcodec.ffmpeg_major_version}"
+
+    if os.name == "nt":
+        suffixes = [".dll"]
+    elif sys.platform == "darwin":
+        suffixes = [".dylib", ".so"]
+    else:
+        suffixes = [".so"]
+
+    candidates = []
+    for suffix in suffixes:
+        candidates.extend(
+            build_dir.rglob(f"torchcodec_third_party_interface_test{ver}{suffix}")
+        )
+
+    assert candidates, f"Could not find built third-party test library in {build_dir}"
+    lib = str(sorted(candidates)[0])
+    return subprocess.run(
+        [sys.executable, "-c", f"import torch; torch.ops.load_library({lib!r})"],
+        cwd=build_dir,
+    )
+
